# 复制为 .env 使用：cp .env.example .env
# .env 已 gitignore，真实值永不入库。

# ember 专用 Cloudflare Tunnel 的 token
# 来源：Cloudflare Zero Trust → Networks → Tunnels → 新建名为 ember 的 tunnel
# （新建，不动旧系统 memory 的 tunnel）
TUNNEL_TOKEN=

# MCP 挂载路径（V2 起）—— 这就是访问密钥本身，没有别的鉴权！
# 公网部署必须改成随机长串，生成：echo "mcp-$(openssl rand -hex 16)"
# 保持默认 mcp = 把记忆读写接口公开给整个互联网。
# （claude.ai 自定义 connector 不支持自定义请求头，所以路径即密钥。）
# 仅本地开发可用默认 mcp。
MCP_PATH=mcp
