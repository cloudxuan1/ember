# 复制为 .env 使用：cp .env.example .env
# .env 已 gitignore，真实值永不入库。

# ember 专用 Cloudflare Tunnel 的 token
# 来源：Cloudflare Zero Trust → Networks → Tunnels → 新建名为 ember 的 tunnel
# （新建，不动旧系统 memory 的 tunnel）
TUNNEL_TOKEN=

# MCP 挂载路径（V2 起），第一层防线：公网部署改成随机长串，
# 生成：echo "mcp-$(openssl rand -hex 16)"。仅本地开发可用默认 mcp。
MCP_PATH=mcp

# OAuth 门禁（claude.ai 网页 connector 的 connect 流程必需，见 app/oauth.py）。
# 三个值都用 openssl rand -hex 32 生成；PASSWORD 是你在浏览器授权页要输的口令，
# 想好记一点可以自己定（别太短）。三个都留空 = 门禁关闭（仅限本地开发）。
EMBER_OAUTH_PASSWORD=
EMBER_OAUTH_ACCESS_TOKEN=
EMBER_OAUTH_REFRESH_TOKEN=

# 审核台（V3）脚本用的 Bearer token，与上面 MCP 的 ACCESS_TOKEN 刻意分开——
# 持有 MCP token 的一方（含 claude.ai 后端）不该开得了审核台。
# 生成：openssl rand -hex 32。留空 = 审核台 API 只认浏览器登录 cookie。
EMBER_REVIEW_TOKEN=

# 公网域名（OAuth 元数据和 Host 白名单用），默认 ember.cloudxuan1.com
PUBLIC_HOST=ember.cloudxuan1.com
